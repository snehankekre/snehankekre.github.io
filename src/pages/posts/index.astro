---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/Layout.astro';
import '~/styles/paper.css';

const posts = (await getCollection('post', ({ data }) => !data.draft)).sort(
  (a, b) => (b.data.publishDate?.valueOf() ?? 0) - (a.data.publishDate?.valueOf() ?? 0)
);

const metadata = {
  title: 'posts',
  description: 'Writing by Snehan Kekre: docs, devrel, open source, and diving.',
};
---

<Layout metadata={metadata}>
  <div class="post-page">
    <header class="post-top">
      <a class="post-brand" href="/">snehan&nbsp;kekre</a>
      <nav>
        <a href="/">home</a>
        <a href="/rss.xml">rss</a>
      </nav>
    </header>

    <main class="post-main">
      <p class="post-label">// posts</p>
      {
        posts.length === 0 ? (
          <p class="post-meta">nothing here yet. soon.</p>
        ) : (
          <ul class="post-list">
            {posts.map((p) => (
              <li>
                <span class="post-date">{p.data.publishDate?.toISOString().slice(0, 10)}</span>
                <a href={`/posts/${p.id}`}>{p.data.title}</a>
                {p.data.excerpt && <p class="post-excerpt">{p.data.excerpt}</p>}
              </li>
            ))}
          </ul>
        )
      }
    </main>
  </div>
</Layout>
