    /* diving certifications ladder */
    .cert-lead { max-width: 38rem; font-size: 1rem; color: var(--muted); margin: 1.4rem 0 0.2rem; font-family: var(--mono); }
    .certs { list-style: none; margin: 0.6rem 0 0; padding: 0; max-width: 40rem; }
    .cert-track { padding: 0.7rem 0; border-top: 1px dashed var(--dash); }
    .cert-track:first-child { border-top: none; }
    .cert-head { font-family: var(--mono); font-size: 0.74rem; text-transform: uppercase; letter-spacing: 0.07em; color: var(--deep); margin: 0; }
    .cert-max { color: var(--accent); }
    .cert-apex { margin: 0.18rem 0 0; font-size: 1.1rem; display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5rem; }
    .cert-apex strong { color: var(--deep); }
