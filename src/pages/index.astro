---
import Layout from '~/layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import '~/styles/paper.css';

const SITE = 'https://snehankekre.com';

// Latest posts for the homepage section (hidden until the first non-draft post ships).
const recentPosts = (await getCollection('post', ({ data }) => !data.draft))
  .sort((a, b) => (b.data.publishDate?.valueOf() ?? 0) - (a.data.publishDate?.valueOf() ?? 0))
  .slice(0, 3);
const RESUME_URL = '/Snehan_Kekre_CV.pdf';
const EMAIL = 'contact@snehankekre.com';
const LINKEDIN = 'https://www.linkedin.com/in/snehankekre/';
const GITHUB = 'https://github.com/snehankekre';
const COURSERA = 'https://www.coursera.org/instructor/snehan-kekre';
const INSTAGRAM = 'https://www.instagram.com/snehankekre/';

// rel="me" identity links — declare these profiles as the same person (helps entity/identity signals).
const ME_LINKS = [LINKEDIN, GITHUB, COURSERA, INSTAGRAM];
const relMe = (href: string | null) => (href && ME_LINKS.includes(href) ? 'me noopener' : 'noopener');

const metadata = {
  title: 'Snehan Kekre · docs, devrel & diving',
  ignoreTitleTemplate: true,
  description:
    'Snehan Kekre leads docs, developer relations, and developer education for open-source developer tools (Streamlit, AstroBee). Also a diver.',
};

// JSON-LD Person structured data: helps search engines tie this site to me as an entity.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Snehan Kekre',
  url: SITE,
  image: `${SITE}/og.png`,
  jobTitle: 'Developer Relations & Documentation Leader',
  description:
    'Leads documentation, developer relations, and developer education for open-source developer tools. Built and ran Streamlit docs and community; Head of Documentation at AstroBee.',
  alumniOf: { '@type': 'CollegeOrUniversity', name: 'Minerva University' },
  knowsAbout: [
    'Developer Relations',
    'Community Building',
    'Technical Writing',
    'Documentation',
    'Documentation Strategy',
    'Developer Education',
    'Technical Product Management',
    'Open Source',
    'Python',
    'Streamlit',
  ],
  sameAs: [LINKEDIN, GITHUB, COURSERA, INSTAGRAM],
};

const work = [
  {
    role: 'Head of Documentation',
    org: 'AstroBee',
    years: '2025–26',
    note: 'docs site + every demo asset, the stuff sales pitched on',
    body: 'Built the documentation site from scratch and owned all of its content, demos, and assets. Pitched in on growth too: content, SEO, experiments.',
  },
  {
    role: 'Technical Product Manager, Streamlit OSS',
    org: 'Snowflake',
    years: '2023–25',
    note: 'top-10 contributor to the repo',
    body: 'Ran the Streamlit open-source library (40k+ stars, 1M+ monthly devs, 90% of the Fortune 50). Shipped features across data-viz, ML, GenAI and geospatial; set roadmap with leadership; was the public face at talks, videos and the blog.',
  },
  {
    role: 'Product Manager, Streamlit Docs',
    org: 'Snowflake',
    years: '2022–23',
    note: null,
    body: 'Owned the whole docs platform (getting-started, tutorials, API reference, search, telemetry) and managed a team of technical writers and content strategists while owning the platform engineering.',
  },
  {
    role: 'Developer Advocate',
    org: 'Streamlit',
    years: '2021–22',
    note: 'joined the 50-person team acquired by Snowflake for $800M',
    body: 'Part of the founding DevRel team: sole technical writer and second DevRel hire. Ran the community forum and was the go-to person when users were stuck; migrated all the docs onto a new Next.js + MDX platform.',
  },
  {
    role: 'ML & Data Science Instructor',
    org: 'Coursera',
    years: '2019–21',
    note: "Coursera's first-ever project instructor",
    body: 'Built 40+ hands-on Guided Projects on ML, deep learning and data viz. 290k+ enrollments.',
  },
];

const projects = [
  {
    name: 'docs.astrobee.ai',
    blurb: 'Docs for an AI agent platform, built from scratch: every guide, demo, and asset the team pitched with.',
    href: 'https://docs.astrobee.ai/',
    link: 'docs.astrobee.ai ↗',
    href2: null,
    link2: null,
  },
  {
    name: 'docs.streamlit.io',
    blurb: 'Migrated off Sphinx/ReadTheDocs onto a custom Next.js + MDX platform, then owned end to end: guides, tutorials, the auto-generated API reference, and the thousands of commits behind them.',
    href: 'https://docs.streamlit.io/',
    link: 'docs.streamlit.io ↗',
    href2: 'https://github.com/streamlit/docs/commits?author=snehankekre',
    link2: 'my commits ↗',
  },
  {
    name: 'community & education',
    blurb: 'Helped start and run the Discord and Slack communities and the creator program, on top of the forum.',
    href: null,
    link: null,
    href2: null,
    link2: null,
  },
  {
    name: 'guided projects on Coursera',
    blurb: 'The first Guided Projects on the platform; every lesson is a notebook the learner builds alongside me.',
    href: 'https://www.coursera.org/instructor/snehan-kekre',
    link: 'coursera.org/instructor/snehan-kekre ↗',
    href2: null,
    link2: null,
  },
];

// Streamlit open-source library work. Two honest buckets: features I product-managed
// (spec, prototypes, research, shipped with engineering) and code I authored myself.
const PR = (n: number) => `https://github.com/streamlit/streamlit/pull/${n}`;
const ALL_PRS =
  'https://github.com/streamlit/streamlit/pulls?q=is%3Apr+author%3Asnehankekre+is%3Amerged';

const pmShipped = [
  { name: 'st.feedback', what: 'new widget', pr: 8915 },
  { name: 'st.pills', what: 'new widget', pr: 9283 },
  { name: 'st.segmented_control', what: 'new widget', pr: 9418 },
  { name: 'st.audio_input', what: 'new widget', pr: 9111 },
  { name: 'st.button + link / download / form / popover', what: 'icon parameters', pr: 9301 },
  { name: 'st.line_chart / st.bar_chart / st.area_chart', what: 'custom axis labels (x_label, y_label)', pr: 8846 },
  { name: 'st.bar_chart', what: 'horizontal bars', pr: 8877 },
  { name: 'st.bar_chart', what: 'stacking', pr: 8945 },
  { name: 'st.area_chart', what: 'stacking', pr: 8992 },
  { name: 'st.video', what: 'subtitles', pr: 8057 },
  { name: 'st.audio / st.video', what: 'start/end time + loop', pr: 8348 },
  { name: 'st.code', what: 'line wrapping (wrap_lines)', pr: 8558 },
  { name: 'st.json', what: 'configurable expansion depth', pr: 8984 },
  { name: 'st.graphviz_chart', what: 'graphviz.Source objects', pr: 8993 },
];

const authored = [
  { name: 'st.expander', what: 'icon parameter', pr: 8716 },
  { name: 'st.audio / st.video', what: 'autoplay support', pr: 8481 },
  { name: 'markdown', what: 'background colors for text', pr: 8435 },
  { name: 'st.graphviz_chart', what: 'Graphviz layout engines', pr: 7505 },
  { name: 'st.metric', what: 'label_visibility parameter', pr: 5789 },
  { name: 'st.map', what: 'theme-aware light/dark basemaps', pr: 5074 },
  { name: 'st.code', what: 'copy-button visibility regression (fix)', pr: 6498 },
  { name: 'st.graphviz_chart', what: 'SVG scaling in fullscreen (fix)', pr: 7398 },
  { name: 'st.slider', what: 'thumb value alignment (fix)', pr: 6828 },
  { name: 'st.toast', what: 'message truncation (fix)', pr: 8337 },
  { name: 'streamlit config show', what: 'honor newlines (fix)', pr: 6758 },
  { name: 'st.json', what: 'preserve whitespace (fix)', pr: 6663 },
  { name: 'st.image', what: 'correct GIF mimetype (fix)', pr: 5438 },
  { name: 'alert elements', what: 'word-wrap fix', pr: 5162 },
];

// Rows of each group visible before the "+ n more" expander (arrays are ordered strongest-first).
const FEATURED = 5;
const shipGroups = [
  { title: 'product-managed', sub: 'spec, prototypes, research, shipped with engineering', items: pmShipped },
  { title: 'authored', sub: 'my commits', items: authored },
];

// Diving certifications: verified credentials, grouped by discipline. head[] lets a track
// list more than one agency (the cave track spans TDI + IANTD).
const PADI_VERIFY = 'https://achievements.padi.com/bec0effb-3f51-4aa7-b9f9-a296d79c1d69';

const certTracks = [
  {
    track: 'instructor',
    maxed: false,
    head: [{ name: 'Open Water Scuba Instructor', agency: 'PADI', href: PADI_VERIFY, note: 'I teach' }],
    steps: [] as string[],
  },
  {
    track: 'open-circuit tech',
    maxed: true,
    head: [{ name: 'Advanced Trimix', agency: 'TDI', href: null, note: 'hypoxic · ~100 m' }],
    steps: ['Advanced Nitrox', 'Decompression Procedures', 'Extended Range', 'Trimix 75 m'],
  },
  {
    track: 'cave',
    maxed: true,
    head: [
      { name: 'Stage Cave', agency: 'TDI', href: null, note: 'beyond full cave' },
      { name: 'Technical Cave Diver', agency: 'IANTD', href: null, note: 'to 55 m' },
    ],
    steps: ['Cavern', 'Intro to Cave', 'Full Cave'],
  },
  {
    track: 'rebreather · CCR',
    maxed: false,
    head: [{ name: 'O2ptima CM Air Diluent', agency: 'TDI', href: null, note: 'chest-mount “Choptima”' }],
    steps: [] as string[],
  },
  {
    track: 'sidemount',
    maxed: false,
    head: [{ name: 'GO Side Mount (Razor)', agency: 'GO', href: null, note: 'Sanctum Exploration · Bali' }],
    steps: [] as string[],
  },
];

// Diving media: drop photos & short clips into src/assets/diving/ and they appear here.
// Filenames become captions, e.g. "01-cenote-dos-ojos.jpg" -> "cenote dos ojos".
// A numeric prefix controls order; images and videos are picked up automatically.
const diveImages = import.meta.glob('../assets/diving/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG,WEBP}', {
  eager: true,
});
const diveVideos = import.meta.glob('../assets/diving/*.{mp4,webm,mov,MP4,WEBM,MOV}', {
  eager: true,
  query: '?url',
  import: 'default',
});
// Poster frames for the video tiles (extracted with ffmpeg, one per video, same
// basename). The grid shows only these; the mp4 downloads when a tile is clicked.
const divePosterImgs = import.meta.glob('../assets/diving/posters/*.{jpg,jpeg,png,webp}', {
  eager: true,
});

// Curated captions (the handwritten note under each frame), keyed by filename.
const diveCaptions: Record<string, string> = {
  '01-technical-cave-diving.mp4': 'Sulawesi, the trip that changed everything',
  '02-100-meter-adv-trimix.mp4': '100m trimix · Tulamben',
  '03-75m-1.webp': '75m, open-circuit sidemount',
  '04-75m-2.webp': 'hypoxic trimix',
  '05-75m-3.webp': 'deep on bottom gas',
  '06-ccr.mp4': 'rebreather on the Tanjung Jepun wreck',
  '07-cave-jump-how-to.mp4': "how to ‘jump’ in a cave",
  '08-cave-diving-optional.mp4': 'the closest thing to peace',
  '09-cave-diving-instructor-praying.mp4': 'will we fit? · Kaponda Ponda',
};

const fileName = (path: string) => path.split('/').pop()!;
const baseName = (path: string) => fileName(path).replace(/\.[^.]+$/, '');
const posterFor = (videoPath: string): ImageMetadata | null => {
  const hit = Object.entries(divePosterImgs).find(([p]) => baseName(p) === baseName(videoPath));
  return hit ? (hit[1] as { default: ImageMetadata }).default : null;
};
const diveCaption = (path: string) =>
  diveCaptions[fileName(path)] ??
  fileName(path)
    .replace(/\.[^.]+$/, '')
    .replace(/^\d+[-_\s]*/, '')
    .replace(/[-_]+/g, ' ')
    .trim();

const dives = [
  ...Object.entries(diveImages).map(([path, mod]) => {
    const img = (mod as { default: ImageMetadata }).default;
    return { path, type: 'image' as const, src: img, full: img.src, cap: diveCaption(path) };
  }),
  ...Object.entries(diveVideos).map(([path, url]) => ({
    path,
    type: 'video' as const,
    src: url as string,
    full: url as string,
    poster: posterFor(path),
    cap: diveCaption(path),
  })),
].sort((a, b) => a.path.localeCompare(b.path));
---

<Layout metadata={metadata}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(personSchema)} />

  <div class="page">
    <header class="topbar">
      <a class="brand" href="#top">snehan kekre</a>
      <nav class="nav">
        <a href="#about">about</a>
        <a href="#work">work</a>
        <a href="#diving">diving</a>
        {recentPosts.length > 0 && <a href="/posts">posts</a>}
        <a href={RESUME_URL} target="_blank" rel="noopener">CV&nbsp;↗</a>
        <button
          type="button"
          class="theme-toggle"
          data-aw-toggle-color-scheme
          aria-label="Toggle dark mode"
          title="Toggle dark / light"
        >
          <span class="i-moon" aria-hidden="true">☾</span><span class="i-sun" aria-hidden="true">☀</span>
        </button>
      </nav>
    </header>

    <main class="wrap" id="top">
      <!-- intro -->
      <section class="intro">
        <h1 class="name">snehan&nbsp;kekre</h1>
        <p class="tag">docs<span class="dot">·</span>devrel<span class="dot">·</span>diver</p>
        <p class="now"><span class="kbd">NOW</span> &rarr; Looking to run docs, devrel, or dev-ed next. Otherwise underwater.</p>
        <p class="hr" id="hr" hidden>
          <span class="hr-heart" aria-hidden="true">&hearts;</span>
          <span class="hr-bpm">--</span> bpm
          <span class="hr-note"><a href="/posts/hr">live, via Garmin</a></span>
        </p>
        <p class="lede">
          I build and run the docs, community, and education around open-source developer tools.
          Second DevRel hire at <strong>Streamlit</strong> (1M+ monthly active devs), I grew from
          sole technical writer to leading its docs team and product-managing the open-source
          library, then built AstroBee's documentation from scratch as Head of Docs.
        </p>
        <p class="links">
          <a href={`mailto:${EMAIL}`} rel="me">email</a>
          <a href={LINKEDIN} target="_blank" rel="me noopener">linkedin</a>
          <a href={GITHUB} target="_blank" rel="me noopener">github</a>
          <a href={RESUME_URL} target="_blank" rel="noopener">CV (pdf)</a>
        </p>
      </section>

      <!-- about / what i do -->
      <section id="about" class="block">
        <h2 class="label">// what i do</h2>
        <ul class="tags">
          <li>developer relations</li>
          <li>technical writing &amp; docs</li>
          <li>developer education</li>
          <li>technical product management</li>
          <li>community support</li>
          <li>python &amp; js/ts</li>
        </ul>
        <p class="about-body">
          The part I love most is the space between a community and the people building for it:
          running the forum, reading what users trip on, and turning it into fixes, features, and
          better docs. I've done that at every altitude: answering threads myself, leading a team
          of writers and content strategists, and setting the roadmap for the library. When
          something needs a tool I haven't touched, I go learn it, and I'll write the guide, ship
          the fix, or record the video, whatever gets a developer unstuck.
        </p>
      </section>

      <!-- work -->
      <section id="work" class="block">
        <h2 class="label">// work</h2>
        <ol class="work">
          {work.map((w) => (
            <li class="job">
              <div class="job-head">
                <span class="job-role">{w.role}</span>
                <span class="job-meta"><span class="job-org">{w.org}</span><span class="sep">/</span>{w.years}</span>
              </div>
              <p class="job-body">{w.body}</p>
              {w.note && <p class="aside">※ {w.note}</p>}
            </li>
          ))}
        </ol>
        <p class="muted-line">
          Full history &amp; education in the <a href={RESUME_URL} target="_blank" rel="noopener">CV&nbsp;↗</a>
          &nbsp;(BS, Physics &amp; CS, Minerva University).
        </p>
      </section>

      <!-- selected work -->
      <section class="block">
        <h2 class="label">// a few things i made</h2>
        <dl class="projects">
          {projects.map((p) => (
            <div class="proj">
              <dt>
                {p.href ? <a href={p.href} target="_blank" rel={relMe(p.href)}>{p.name}</a> : p.name}
              </dt>
              <dd>
                {p.blurb}
                {p.href && <> <a class="proj-link" href={p.href} target="_blank" rel={relMe(p.href)}>{p.link}</a></>}
                {p.href2 && <> <a class="proj-link" href={p.href2} target="_blank" rel="noopener">{p.link2}</a></>}
              </dd>
            </div>
          ))}
        </dl>
      </section>

      <!-- streamlit, the library -->
      <section id="streamlit" class="block">
        <h2 class="label">// streamlit, the library</h2>
        <p class="ship-intro">
          Docs were only half the job. As technical PM for Streamlit's open-source library I ran
          features end to end and authored a fair bit of the code and bug fixes myself.
          <a href={ALL_PRS} target="_blank" rel="noopener">89 merged PRs&nbsp;↗</a>
        </p>

        {shipGroups.map((g) => (
          <div class="ship-group">
            <h3 class="ship-head">{g.title} <span>· {g.sub}</span></h3>
            <ul class="ships">
              {g.items.slice(0, FEATURED).map((s) => (
                <li>
                  <a href={PR(s.pr)} target="_blank" rel="noopener">
                    <code>{s.name}</code>
                    <span class="ship-what">{s.what}</span>
                    <span class="ship-pr">#{s.pr}&nbsp;↗</span>
                  </a>
                </li>
              ))}
            </ul>
            {g.items.length > FEATURED && (
              <details class="ships-more">
                <summary>
                  <span class="when-closed">+ {g.items.length - FEATURED} more ↓</span>
                  <span class="when-open">− show less ↑</span>
                </summary>
                <ul class="ships">
                  {g.items.slice(FEATURED).map((s) => (
                    <li>
                      <a href={PR(s.pr)} target="_blank" rel="noopener">
                        <code>{s.name}</code>
                        <span class="ship-what">{s.what}</span>
                        <span class="ship-pr">#{s.pr}&nbsp;↗</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            )}
          </div>
        ))}
      </section>

      <!-- posts (hidden until the first post ships) -->
      {
        recentPosts.length > 0 && (
          <section id="posts" class="block">
            <h2 class="label">// posts</h2>
            <ul class="post-list">
              {recentPosts.map((p) => (
                <li>
                  <span class="post-date">{p.data.publishDate?.toISOString().slice(0, 10)}</span>
                  <a href={`/posts/${p.id}`}>{p.data.title}</a>
                </li>
              ))}
            </ul>
            <p class="muted-line">
              <a href="/posts">all posts</a> · <a href="/rss.xml">rss</a>
            </p>
          </section>
        )
      }

      <!-- diving (zine) -->
      <section id="diving" class="block diving">
        <h2 class="label">// off the keyboard</h2>
        <p class="dive-intro">
          When I'm not shipping docs I'm underwater. Diving, and especially <em>cave</em> diving,
          is where I go to slow down, solve problems, and stay calm when it counts.
        </p>

        <p class="cert-lead">The paper trail: instructor, then maxed out on open-circuit tech and cave, all inside a year.</p>
        <ul class="certs">
          {certTracks.map((t) => (
            <li class="cert-track">
              <p class="cert-head">{t.track}{t.maxed && <span class="cert-max"> · maxed out</span>}</p>
              {t.head.map((h: { name: string; agency: string; href: string | null; note: string }) => (
                <p class="cert-apex">
                  <strong>{h.name}</strong>
                  <span class="cert-agency">{h.agency}</span>
                  {h.href && <a class="cert-verify" href={h.href} target="_blank" rel="noopener">verify&nbsp;↗</a>}
                  {h.note && <span class="cert-note">{h.note}</span>}
                </p>
              ))}
              {t.steps.length > 0 && <p class="cert-steps">↑ {t.steps.join(' · ')}</p>}
            </li>
          ))}
        </ul>

        <div class="polaroids">
          {dives.map((d) => (
            <figure
              class:list={['polaroid', { 'is-video': d.type === 'video' }]}
              role="button"
              tabindex="0"
              aria-label={`Open ${d.cap}`}
              data-lb-type={d.type}
              data-lb-src={d.full}
              data-lb-cap={d.cap}
            >
              <div class="pol-frame">
                {d.type === 'image' ? (
                  <Image class="pol-media" src={d.src} alt={d.cap} width={520} loading="lazy" />
                ) : d.poster ? (
                  <Fragment>
                    <Image class="pol-media" src={d.poster} alt={d.cap} width={520} loading="lazy" />
                    <span class="play-badge" aria-hidden="true">▶</span>
                  </Fragment>
                ) : (
                  <Fragment>
                    {/* no extracted poster yet: keep a video tile but fetch nothing up front */}
                    <video class="pol-media" src={d.src} muted playsinline preload="none"></video>
                    <span class="play-badge" aria-hidden="true">▶</span>
                  </Fragment>
                )}
              </div>
              <figcaption>{d.cap}</figcaption>
            </figure>
          ))}
        </div>
        {dives.length === 0 && (
          <p class="hint">
            add diving photos &amp; clips to <code>src/assets/diving/</code>. Filenames become captions.
          </p>
        )}
        <p class="dive-follow"><a href={INSTAGRAM} target="_blank" rel="me noopener">more on instagram&nbsp;↗</a></p>
      </section>

      <!-- lightbox -->
      <dialog id="lightbox" class="lightbox">
        <button class="lb-close" aria-label="Close">✕</button>
        <div class="lb-stage"></div>
        <p class="lb-cap"></p>
      </dialog>

      <!-- footer -->
      <footer class="foot">
        <p class="foot-cta">Need someone to run docs, devrel, or dev-ed? <a href={`mailto:${EMAIL}`}>Say hi&nbsp;↗</a></p>
        <p class="foot-meta">
          <a href={`mailto:${EMAIL}`} rel="me">email</a> ·
          <a href={LINKEDIN} target="_blank" rel="me noopener">linkedin</a> ·
          <a href={GITHUB} target="_blank" rel="me noopener">github</a>
        </p>
        <p class="foot-note">© {new Date().getFullYear()} snehan kekre · built by hand with astro.</p>
      </footer>
    </main>
  </div>

  <!-- oneko: the little cat that chases your cursor -->
  <script is:inline defer src="/oneko.js"></script>

  <script>
    // Heart-rate widget: replays Garmin data with a 24h offset, linearly
    // interpolated between ~2-min samples and re-ticked every 10s.
    // ClientRouter swaps the DOM without re-running modules, so element lookups
    // happen inside tick() and init re-runs on astro:page-load.
    type HrData = { points: [number, number][] } | null;

    const DAY = 86_400_000;
    const GAP = 20 * 60 * 1000; // treat holes wider than this as no-signal
    let hrFetch: Promise<HrData> | undefined;
    let hrData: HrData = null;
    let hrTimer: ReturnType<typeof setInterval> | undefined;

    const sample = (pts: [number, number][], t: number): number | null => {
      const first = pts[0][0];
      const last = pts[pts.length - 1][0];
      if (t > last) t -= DAY; // just past the data day (pre-refresh); replay it
      if (t < first - GAP || t > last + GAP) return null;
      let prev: [number, number] | null = null;
      let next: [number, number] | null = null;
      for (const p of pts) {
        if (p[0] <= t) prev = p;
        else {
          next = p;
          break;
        }
      }
      if (!prev) return next && next[0] - t <= GAP ? next[1] : null;
      if (!next || next[0] - prev[0] > GAP) return t - prev[0] <= GAP ? prev[1] : null;
      const f = (t - prev[0]) / (next[0] - prev[0]);
      return Math.round(prev[1] + f * (next[1] - prev[1]));
    };

    const tick = () => {
      const hrEl = document.getElementById('hr');
      const bpmEl = hrEl?.querySelector('.hr-bpm');
      const heartEl = hrEl?.querySelector('.hr-heart') as HTMLElement | null;
      if (!hrEl || !bpmEl || !heartEl || !hrData?.points?.length) return;
      const bpm = sample(hrData.points, Date.now() - DAY);
      if (bpm == null) {
        hrEl.hidden = true;
        return;
      }
      bpmEl.textContent = String(bpm);
      heartEl.style.setProperty('--beat', `${(60 / bpm).toFixed(3)}s`);
      hrEl.hidden = false;
    };

    const initHr = async () => {
      if (!document.getElementById('hr')) return; // not on this page
      hrFetch ??= fetch('/hr.json')
        .then((r) => (r.ok ? r.json() : null))
        .catch(() => null);
      hrData = await hrFetch;
      tick();
      hrTimer ??= setInterval(tick, 10_000);
    };

    initHr();
    document.addEventListener('astro:page-load', initHr);
  </script>

  <script>
    // Diving-gallery lightbox. Re-wired after every ClientRouter swap; the
    // data-wired flag keeps the immediate call + astro:page-load from double-binding.
    const initLightbox = () => {
      const dlg = document.getElementById('lightbox') as HTMLDialogElement | null;
      if (!dlg || dlg.dataset.wired) return;
      dlg.dataset.wired = '1';
      const stage = dlg.querySelector('.lb-stage') as HTMLElement;
      const cap = dlg.querySelector('.lb-cap') as HTMLElement;

      const openLb = (el: HTMLElement) => {
        const type = el.dataset.lbType;
        const src = el.dataset.lbSrc || '';
        const c = el.dataset.lbCap || '';
        stage.innerHTML = '';
        if (type === 'video') {
          const v = document.createElement('video');
          v.src = src;
          v.controls = true;
          v.autoplay = true;
          v.playsInline = true;
          v.className = 'lb-media';
          stage.appendChild(v);
        } else {
          const img = document.createElement('img');
          img.src = src;
          img.alt = c;
          img.className = 'lb-media';
          stage.appendChild(img);
        }
        cap.textContent = c;
        dlg.showModal();
      };

      const closeLb = () => {
        const v = stage.querySelector('video');
        if (v) v.pause();
        stage.innerHTML = '';
        if (dlg.open) dlg.close();
      };

      document.querySelectorAll<HTMLElement>('.polaroid').forEach((p) => {
        p.addEventListener('click', () => openLb(p));
        p.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            openLb(p);
          }
        });
      });

      dlg.querySelector('.lb-close')?.addEventListener('click', closeLb);
      // click on backdrop (outside the media) closes
      dlg.addEventListener('click', (e) => {
        if (e.target === dlg) closeLb();
      });
      dlg.addEventListener('close', closeLb);
    };

    initLightbox();
    document.addEventListener('astro:page-load', initLightbox);
  </script>

