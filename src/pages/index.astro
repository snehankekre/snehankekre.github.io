    /* gallery breaks out wider than the text column for room to breathe */
    .polaroids {
      display: flex; flex-wrap: wrap; gap: 2.2rem 1.8rem; margin: 2.2rem 0 0.6rem;
      justify-content: center; align-items: flex-start;
      width: min(60rem, 92vw); position: relative; left: 50%; transform: translateX(-50%);
    }
    .polaroid {
      margin: 0; background: #fff; padding: 0.6rem 0.6rem 0; width: 15rem; cursor: pointer;
      border: 1px solid #d7cdbb; box-shadow: 2px 5px 0 rgba(24,18,12,0.18);
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }
    .pol-frame { position: relative; }
    .polaroid .pol-media { display: block; width: 100%; height: 11.5rem; object-fit: cover; background: #11212b; }
    /* vertical reels get taller, portrait frames so the footage isn't cropped to a sliver */
    .polaroid.is-video { width: 13rem; }
    .polaroid.is-video .pol-media { height: 21rem; }
    .play-badge {
      position: absolute; inset: 0; margin: auto; width: 3rem; height: 3rem;
      display: flex; align-items: center; justify-content: center; border-radius: 50%;
      background: rgba(24,18,12,0.55); color: #fff; font-size: 1.05rem; padding-left: 0.15rem;
      pointer-events: none;
