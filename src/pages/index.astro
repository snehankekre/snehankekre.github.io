    .polaroids {
      display: grid; grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 2.8rem 2rem; margin: 2.4rem 0 0.6rem; justify-items: center;
      width: min(54rem, 92vw); position: relative; left: 50%; transform: translateX(-50%);
    }
    .polaroid {
      margin: 0; background: #fff; padding: 0.6rem 0.6rem 0; width: 100%; max-width: 16rem; cursor: pointer;
      border: 1px solid #d7cdbb; box-shadow: 2px 5px 0 rgba(24,18,12,0.18);
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }
    .pol-frame { position: relative; }
    /* every frame is the same 4:5 portrait; cover-crops uniformly, full media shows in the lightbox */
    .polaroid .pol-media { display: block; width: 100%; aspect-ratio: 4 / 5; height: auto; object-fit: cover; background: #11212b; }
    .play-badge {
      position: absolute; inset: 0; margin: auto; width: 3rem; height: 3rem;
      display: flex; align-items: center; justify-content: center; border-radius: 50%;
      background: rgba(24,18,12,0.55); color: #fff; font-size: 1.05rem; padding-left: 0.15rem;
      pointer-events: none;
    }
