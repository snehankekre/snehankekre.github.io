---
import Layout from '~/layouts/Layout.astro';
import { Image } from 'astro:assets';

const SITE = 'https://snehankekre.com';
const RESUME_URL = '/Snehan_Kekre_CV.pdf';
const EMAIL = 'snehan.minerva@gmail.com';
const LINKEDIN = 'https://www.linkedin.com/in/snehankekre/';
const GITHUB = 'https://github.com/snehankekre';
const COURSERA = 'https://www.coursera.org/instructor/snehan-kekre';
const INSTAGRAM = 'https://www.instagram.com/snehankekre/';

const metadata = {
  title: 'Snehan Kekre — docs, devrel & diving',
  ignoreTitleTemplate: true,
  description:
    'Snehan Kekre is an open-source developer relations and documentation leader (Streamlit). Community, docs, and developer education — and a diver.',
};

// JSON-LD Person structured data — helps search engines tie this site to me as an entity.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Snehan Kekre',
  url: SITE,
  image: `${SITE}/og.png`,
  jobTitle: 'Developer Relations & Documentation Leader',
  description:
    'Open-source developer relations and documentation leader. Community support, technical writing, and developer education.',
  alumniOf: { '@type': 'CollegeOrUniversity', name: 'Minerva University' },
  knowsAbout: [
    'Developer Relations',
    'Community Support',
    'Technical Writing',
    'Documentation',
    'Developer Education',
    'Open Source',
    'Python',
    'Streamlit',
  ],
  sameAs: [LINKEDIN, GITHUB, COURSERA, INSTAGRAM],
};

const work = [
  {
    role: 'Head of Documentation',
    org: 'AstroBee',
    years: '2025–26',
    note: 'docs site + every demo asset, the stuff sales pitched on',
    body: 'Built the documentation site from scratch and owned all of its content, demos, and assets. Pitched in on growth too: content, SEO, experiments.',
  },
  {
    role: 'Technical Product Manager, Streamlit OSS',
    org: 'Snowflake',
    years: '2023–25',
    note: 'top-10 contributor to the repo',
    body: 'Ran the Streamlit open-source library (40k+ stars, 1M+ monthly devs, 90% of the Fortune 50). Shipped features across data-viz, ML, GenAI and geospatial; set roadmap with leadership; was the public face at talks, videos and the blog.',
  },
  {
    role: 'Product Manager, Streamlit Docs',
    org: 'Snowflake',
    years: '2022–23',
    note: null,
    body: 'Owned the whole docs platform — getting-started, tutorials, API reference, search, telemetry — and managed a team of technical writers and content strategists while owning the platform engineering.',
  },
  {
    role: 'Developer Advocate',
    org: 'Streamlit',
    years: '2021–22',
    note: 'joined the 50-person team acquired by Snowflake for $800M',
    body: 'Ran the community forum and was the go-to person when users were stuck. Sole technical writer + second DevRel hire; migrated all the docs onto a new Next.js + MDX platform.',
  },
  {
    role: 'ML & Data Science Instructor',
    org: 'Coursera',
    years: '2019–21',
    note: "Coursera's first-ever project instructor",
    body: 'Built 40+ hands-on Guided Projects on ML, deep learning and data viz. 290k+ enrollments.',
  },
];

const projects = [
  {
    name: 'docs.astrobee.ai',
    blurb: 'Built the AstroBee documentation site from scratch and owned all of its content, demos, and assets — the material the team pitched to prospective customers.',
    href: 'https://docs.astrobee.ai/',
    link: 'docs.astrobee.ai ↗',
    href2: null,
    link2: null,
  },
  {
    name: 'docs.streamlit.io',
    blurb: 'I ran docs for Streamlit. Migrated the whole site off Sphinx/ReadTheDocs onto a custom Next.js + MDX platform, then owned all of it end to end — guides, tutorials, the auto-generated API reference, and the thousands of commits behind them. Repo’s top contributor.',
    href: 'https://docs.streamlit.io/',
    link: 'docs.streamlit.io ↗',
    href2: 'https://github.com/streamlit/docs/commits?author=snehankekre',
    link2: 'my commits ↗',
  },
  {
    name: 'community & education',
    blurb: 'Ran the forum; helped start and run the Discord and Slack communities and the creator program. The connective tissue between users and the team.',
    href: null,
    link: null,
    href2: null,
    link2: null,
  },
  {
    name: 'guided projects on Coursera',
    blurb: 'Built 40+ hands-on Guided Projects on ML, deep learning and data viz. 290k+ enrollments.',
    href: 'https://www.coursera.org/instructor/snehan-kekre',
    link: 'coursera.org/instructor/snehan-kekre ↗',
    href2: null,
    link2: null,
  },
];

// Streamlit open-source library work. Two honest buckets: features I product-managed
// (spec, prototypes, research, shipped with engineering) and code I authored myself.
const PR = (n: number) => `https://github.com/streamlit/streamlit/pull/${n}`;
const ALL_PRS =
  'https://github.com/streamlit/streamlit/pulls?q=is%3Apr+author%3Asnehankekre+is%3Amerged';

const pmShipped = [
  { name: 'st.feedback', what: 'new widget', pr: 8915 },
  { name: 'st.pills', what: 'new widget', pr: 9283 },
  { name: 'st.segmented_control', what: 'new widget', pr: 9418 },
  { name: 'st.audio_input', what: 'new widget', pr: 9111 },
  { name: 'st.button + link / download / form / popover', what: 'icon parameters', pr: 9301 },
  { name: 'st.line_chart / st.bar_chart / st.area_chart', what: 'custom axis labels (x_label, y_label)', pr: 8846 },
  { name: 'st.bar_chart', what: 'horizontal bars', pr: 8877 },
  { name: 'st.bar_chart', what: 'stacking', pr: 8945 },
  { name: 'st.area_chart', what: 'stacking', pr: 8992 },
  { name: 'st.video', what: 'subtitles', pr: 8057 },
  { name: 'st.audio / st.video', what: 'start/end time + loop', pr: 8348 },
  { name: 'st.code', what: 'line wrapping (wrap_lines)', pr: 8558 },
  { name: 'st.json', what: 'configurable expansion depth', pr: 8984 },
  { name: 'st.graphviz_chart', what: 'graphviz.Source objects', pr: 8993 },
];

const authored = [
  { name: 'st.expander', what: 'icon parameter', pr: 8716 },
  { name: 'st.audio / st.video', what: 'autoplay support', pr: 8481 },
  { name: 'markdown', what: 'background colors for text', pr: 8435 },
  { name: 'st.graphviz_chart', what: 'Graphviz layout engines', pr: 7505 },
  { name: 'st.metric', what: 'label_visibility parameter', pr: 5789 },
  { name: 'st.map', what: 'theme-aware light/dark basemaps', pr: 5074 },
  { name: 'st.code', what: 'copy-button visibility regression (fix)', pr: 6498 },
  { name: 'st.graphviz_chart', what: 'SVG scaling in fullscreen (fix)', pr: 7398 },
  { name: 'st.slider', what: 'thumb value alignment (fix)', pr: 6828 },
  { name: 'st.toast', what: 'message truncation (fix)', pr: 8337 },
  { name: 'streamlit config show', what: 'honor newlines (fix)', pr: 6758 },
  { name: 'st.json', what: 'preserve whitespace (fix)', pr: 6663 },
  { name: 'st.image', what: 'correct GIF mimetype (fix)', pr: 5438 },
  { name: 'alert elements', what: 'word-wrap fix', pr: 5162 },
];

// Diving media — drop photos & short clips into src/assets/diving/ and they appear here.
// Filenames become captions, e.g. "01-cenote-dos-ojos.jpg" -> "cenote dos ojos".
// A numeric prefix controls order; images and videos are picked up automatically.
const diveImages = import.meta.glob('../assets/diving/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG,WEBP}', {
  eager: true,
});
const diveVideos = import.meta.glob('../assets/diving/*.{mp4,webm,mov,MP4,WEBM,MOV}', {
  eager: true,
  query: '?url',
  import: 'default',
});

// Curated captions (the handwritten note under each frame), keyed by filename.
const diveCaptions: Record<string, string> = {
  '01-technical-cave-diving.mp4': 'Sulawesi — the trip that changed everything',
  '02-100-meter-adv-trimix.mp4': '100m trimix · Tulamben',
  '03-75m-1.webp': '75m, open-circuit sidemount',
  '04-75m-2.webp': 'hypoxic trimix',
  '05-75m-3.webp': 'deep on bottom gas',
  '06-ccr.mp4': 'rebreather on the Tanjung Jepun wreck',
  '07-cave-jump-how-to.mp4': "how to ‘jump’ in a cave",
  '08-cave-diving-optional.mp4': 'the closest thing to peace',
  '09-cave-diving-instructor-praying.mp4': 'will we fit? — Kaponda Ponda',
};

const fileName = (path: string) => path.split('/').pop()!;
const diveCaption = (path: string) =>
  diveCaptions[fileName(path)] ??
  fileName(path)
    .replace(/\.[^.]+$/, '')
    .replace(/^\d+[-_\s]*/, '')
    .replace(/[-_]+/g, ' ')
    .trim();

const dives = [
  ...Object.entries(diveImages).map(([path, mod]) => {
    const img = (mod as { default: ImageMetadata }).default;
    return { path, type: 'image' as const, src: img, full: img.src, cap: diveCaption(path) };
  }),
  ...Object.entries(diveVideos).map(([path, url]) => ({
    path,
    type: 'video' as const,
    src: url as string,
    full: url as string,
    cap: diveCaption(path),
  })),
].sort((a, b) => a.path.localeCompare(b.path));
---

<Layout metadata={metadata}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(personSchema)} />

  <div class="page">
    <header class="topbar">
      <a class="brand" href="#top">snehan kekre</a>
      <nav class="nav">
        <a href="#about">about</a>
        <a href="#work">work</a>
        <a href="#diving">diving</a>
        <a href={RESUME_URL} target="_blank" rel="noopener">CV&nbsp;↗</a>
      </nav>
    </header>

    <main class="wrap" id="top">
      <!-- intro -->
      <section class="intro">
        <h1 class="name">snehan&nbsp;kekre</h1>
        <p class="tag">docs<span class="dot">·</span>devrel<span class="dot">·</span>diver</p>
        <p class="now"><span class="kbd">NOW</span> &rarr; Looking for my next community / docs role. Otherwise underwater.</p>
        <p class="lede">
          I'm an open-source developer-relations and documentation person. I built and ran the docs
          and support community for <strong>Streamlit</strong> (1M+ monthly active devs), fixed most
          of the things people got stuck on, and acted as the bridge between users and the team
          building the product — and product-managed a stack of features into the library myself.
        </p>
        <p class="links">
          <a href={`mailto:${EMAIL}`}>email</a>
          <a href={LINKEDIN} target="_blank" rel="noopener">linkedin</a>
          <a href={GITHUB} target="_blank" rel="noopener">github</a>
          <a href={RESUME_URL} target="_blank" rel="noopener">CV (pdf)</a>
        </p>
      </section>

      <!-- about / what i do -->
      <section id="about" class="block">
        <h2 class="label">// what i do</h2>
        <ul class="tags">
          <li>developer relations</li>
          <li>community support</li>
          <li>technical writing &amp; docs</li>
          <li>developer education</li>
          <li>technical product management</li>
          <li>python &amp; js/ts</li>
        </ul>
        <p class="about-body">
          I joined Snowflake through its acquisition of Streamlit, owned the open-source library's
          docs, then product-managed features end to end — and ranked among the project's top
          contributors on the way. Whenever a feature needed a new tool, I was the one to go learn it.
          The part I love most is being the bridge between a community and the people who build for it.
        </p>
      </section>

      <!-- work -->
      <section id="work" class="block">
        <h2 class="label">// work</h2>
        <ol class="work">
          {work.map((w) => (
            <li class="job">
              <div class="job-head">
                <span class="job-role">{w.role}</span>
                <span class="job-meta"><span class="job-org">{w.org}</span><span class="sep">/</span>{w.years}</span>
              </div>
              <p class="job-body">{w.body}</p>
              {w.note && <p class="aside">※ {w.note}</p>}
            </li>
          ))}
        </ol>
        <p class="muted-line">
          Full history &amp; education in the <a href={RESUME_URL} target="_blank" rel="noopener">CV&nbsp;↗</a>
          &nbsp;(BS, Physics &amp; CS — Minerva University).
        </p>
      </section>

      <!-- selected work -->
      <section class="block">
        <h2 class="label">// a few things i made</h2>
        <dl class="projects">
          {projects.map((p) => (
            <div class="proj">
              <dt>
                {p.href ? <a href={p.href} target="_blank" rel="noopener">{p.name}</a> : p.name}
              </dt>
              <dd>
                {p.blurb}
                {p.href && <> <a class="proj-link" href={p.href} target="_blank" rel="noopener">{p.link}</a></>}
                {p.href2 && <> <a class="proj-link" href={p.href2} target="_blank" rel="noopener">{p.link2}</a></>}
              </dd>
            </div>
          ))}
        </dl>
      </section>

      <!-- streamlit, the library -->
      <section id="streamlit" class="block">
        <h2 class="label">// streamlit, the library</h2>
        <p class="ship-intro">
          Not just docs. As technical PM for Streamlit's open-source library I product-managed
          features end to end — product spec, early prototypes, user research, then shipping with a
          team of engineers — and authored a fair bit of the code and bug fixes myself.
          <a href={ALL_PRS} target="_blank" rel="noopener">89 merged PRs&nbsp;↗</a>
        </p>

        <div class="ship-group">
          <h3 class="ship-head">product-managed <span>· spec, prototypes, research, shipped with engineering</span></h3>
          <ul class="ships">
            {pmShipped.map((s) => (
              <li>
                <a href={PR(s.pr)} target="_blank" rel="noopener">
                  <code>{s.name}</code>
                  <span class="ship-what">{s.what}</span>
                  <span class="ship-pr">#{s.pr}&nbsp;↗</span>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="ship-group">
          <h3 class="ship-head">authored <span>· my commits</span></h3>
          <ul class="ships">
            {authored.map((s) => (
              <li>
                <a href={PR(s.pr)} target="_blank" rel="noopener">
                  <code>{s.name}</code>
                  <span class="ship-what">{s.what}</span>
                  <span class="ship-pr">#{s.pr}&nbsp;↗</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- diving (zine) -->
      <section id="diving" class="block diving">
        <h2 class="label">// off the keyboard</h2>
        <p class="dive-intro">
          When I'm not shipping docs I'm underwater. Diving — and especially <em>cave</em> diving —
          is where I go to slow down, solve problems, and stay calm when it counts.
        </p>

        <div class="polaroids">
          {dives.map((d) => (
            <figure
              class:list={['polaroid', { 'is-video': d.type === 'video' }]}
              role="button"
              tabindex="0"
              aria-label={`Open ${d.cap}`}
              data-lb-type={d.type}
              data-lb-src={d.full}
              data-lb-cap={d.cap}
            >
              <div class="pol-frame">
                {d.type === 'image' ? (
                  <Image class="pol-media" src={d.src} alt={d.cap} width={520} loading="lazy" />
                ) : (
                  <Fragment>
                    <video class="pol-media" src={`${d.src}#t=0.1`} muted playsinline preload="metadata"></video>
                    <span class="play-badge" aria-hidden="true">▶</span>
                  </Fragment>
                )}
              </div>
              <figcaption>{d.cap}</figcaption>
            </figure>
          ))}
        </div>
        {dives.length === 0 && (
          <p class="hint">
            add diving photos &amp; clips to <code>src/assets/diving/</code> — filenames become captions.
          </p>
        )}
        <p class="dive-follow"><a href={INSTAGRAM} target="_blank" rel="noopener">more on instagram&nbsp;↗</a></p>
      </section>

      <!-- lightbox -->
      <dialog id="lightbox" class="lightbox">
        <button class="lb-close" aria-label="Close">✕</button>
        <div class="lb-stage"></div>
        <p class="lb-cap"></p>
      </dialog>

      <!-- footer -->
      <footer class="foot">
        <p class="foot-cta">Building a community, docs, or dev-ed program? <a href={`mailto:${EMAIL}`}>Say hi&nbsp;↗</a></p>
        <p class="foot-meta">
          <a href={`mailto:${EMAIL}`}>email</a> ·
          <a href={LINKEDIN} target="_blank" rel="noopener">linkedin</a> ·
          <a href={GITHUB} target="_blank" rel="noopener">github</a>
        </p>
        <p class="foot-note">© {new Date().getFullYear()} snehan kekre · built by hand with astro · no cookies, no tracking.</p>
      </footer>
    </main>
  </div>

  <script>
    const dlg = document.getElementById('lightbox') as HTMLDialogElement | null;
    if (dlg) {
      const stage = dlg.querySelector('.lb-stage') as HTMLElement;
      const cap = dlg.querySelector('.lb-cap') as HTMLElement;

      const openLb = (el: HTMLElement) => {
        const type = el.dataset.lbType;
        const src = el.dataset.lbSrc || '';
        const c = el.dataset.lbCap || '';
        stage.innerHTML = '';
        if (type === 'video') {
          const v = document.createElement('video');
          v.src = src;
          v.controls = true;
          v.autoplay = true;
          v.playsInline = true;
          v.className = 'lb-media';
          stage.appendChild(v);
        } else {
          const img = document.createElement('img');
          img.src = src;
          img.alt = c;
          img.className = 'lb-media';
          stage.appendChild(img);
        }
        cap.textContent = c;
        dlg.showModal();
      };

      const closeLb = () => {
        const v = stage.querySelector('video');
        if (v) v.pause();
        stage.innerHTML = '';
        if (dlg.open) dlg.close();
      };

      document.querySelectorAll<HTMLElement>('.polaroid').forEach((p) => {
        p.addEventListener('click', () => openLb(p));
        p.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            openLb(p);
          }
        });
      });

      dlg.querySelector('.lb-close')?.addEventListener('click', closeLb);
      // click on backdrop (outside the media) closes
      dlg.addEventListener('click', (e) => {
        if (e.target === dlg) closeLb();
      });
      dlg.addEventListener('close', closeLb);
    }
  </script>

  <style is:global>
    :root {
      --paper: #f4f1e9;
      --ink: #18120c;
      --muted: #756c5f;
      --accent: #cc3a1d;
      --deep: #0e3a52;
      --line: #18120c;
      --mono: 'JetBrains Mono', ui-monospace, 'SFMono-Regular', Menlo, monospace;
      --serif: 'Newsreader', Georgia, 'Times New Roman', serif;
      --hand: 'Caveat', cursive;
    }

    html { scroll-behavior: smooth; }
    body { background: var(--paper) !important; }

    .page {
      min-height: 100vh;
      background:
        var(--paper);
      color: var(--ink);
      font-family: var(--mono);
      font-size: 15px;
      line-height: 1.6;
    }

    a { color: var(--ink); text-decoration: underline; text-underline-offset: 3px; text-decoration-thickness: 1px; }
    a:hover { color: var(--accent); }

    /* top bar */
    .topbar {
      position: sticky; top: 0; z-index: 10;
      display: flex; justify-content: space-between; align-items: center;
      gap: 1rem; flex-wrap: wrap;
      padding: 0.75rem 1.25rem;
      background: var(--paper);
      border-bottom: 2px solid var(--line);
    }
    .brand { font-weight: 700; text-transform: lowercase; text-decoration: none; letter-spacing: -0.02em; }
    .nav { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 0.5rem 1rem; font-size: 13px; }
    .nav a { text-decoration: none; white-space: nowrap; }
    .nav a:hover { text-decoration: underline; }

    .wrap { max-width: 46rem; margin: 0 auto; padding: 2.5rem 1.25rem 4rem; }

    /* intro */
    .name { font-size: clamp(2.2rem, 8vw, 3.6rem); font-weight: 700; letter-spacing: -0.04em; line-height: 1; margin: 0.5rem 0 0.4rem; }
    .tag { font-size: 0.95rem; color: var(--muted); letter-spacing: 0.04em; margin: 0 0 1.1rem; }
    .tag .dot { margin: 0 0.5rem; color: var(--accent); }
    .now {
      display: inline-block; font-size: 0.82rem; color: var(--ink);
      border: 1.5px solid var(--line); padding: 0.35rem 0.6rem; margin: 0 0 1.4rem;
    }
    .kbd { background: var(--accent); color: var(--paper); padding: 0 0.35rem; font-weight: 700; }
    /* prose layer: serif, for contrast against the mono structure */
    .lede, .about-body, .job-body, .proj dd, .dive-intro, .foot-cta {
      font-family: var(--serif);
      letter-spacing: 0;
    }
    .lede { font-size: 1.3rem; line-height: 1.5; max-width: 36rem; margin: 0 0 1.3rem; }
    .lede strong { font-weight: 500; font-style: italic; }
    .links { display: flex; flex-wrap: wrap; gap: 1.1rem; font-size: 0.9rem; }

    /* blocks */
    .block { margin-top: 3.2rem; }
    .label { font-size: 0.8rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); border-bottom: 2px solid var(--line); padding-bottom: 0.4rem; margin: 0 0 1.4rem; }

    /* tags */
    .tags { list-style: none; padding: 0; margin: 0 0 1.3rem; display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .tags li { border: 1.5px solid var(--line); padding: 0.2rem 0.6rem; font-size: 0.82rem; }
    .about-body { max-width: 38rem; font-size: 1.12rem; line-height: 1.65; }

    /* work */
    .work { list-style: none; padding: 0; margin: 0; }
    .job { padding: 1.1rem 0; border-top: 1px dashed #b9b0a1; }
    .job:first-child { border-top: none; padding-top: 0; }
    .job-head { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; align-items: baseline; }
    .job-role { font-weight: 700; }
    .job-meta { font-size: 0.82rem; color: var(--muted); white-space: nowrap; }
    .job-org { color: var(--deep); }
    .job-meta .sep { margin: 0 0.4rem; }
    .job-body { margin: 0.45rem 0 0; max-width: 40rem; font-size: 1.1rem; line-height: 1.6; }
    .aside { font-size: 0.82rem; color: var(--accent); margin: 0.4rem 0 0; }
    .muted-line { font-size: 0.85rem; color: var(--muted); margin-top: 1.4rem; }

    /* projects */
    .projects { margin: 0; }
    .proj { padding: 1rem 0; border-top: 1px dashed #b9b0a1; }
    .proj:first-child { border-top: none; padding-top: 0; }
    .proj dt { font-weight: 700; color: var(--deep); }
    .proj dt a { color: var(--deep); }
    .proj dd { margin: 0.4rem 0 0; max-width: 40rem; font-size: 1.1rem; line-height: 1.6; }
    .proj-link { white-space: nowrap; font-family: var(--mono); font-size: 0.85rem; }

    /* streamlit library work */
    .ship-intro { max-width: 42rem; font-size: 1.05rem; line-height: 1.6; margin: 0 0 0.4rem; }
    .ship-group { margin-top: 1.6rem; }
    .ship-head { font-family: var(--mono); font-size: 0.78rem; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--accent); margin: 0 0 0.3rem; }
    .ship-head span { color: var(--muted); text-transform: none; letter-spacing: 0; }
    .ships { list-style: none; margin: 0; padding: 0; }
