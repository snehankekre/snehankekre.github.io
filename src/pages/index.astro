    .lb-stage { display: flex; align-items: center; justify-content: center; }
    .lb-media { display: block; max-width: 92vw; max-height: 82vh; width: auto; height: auto; border: 0.4rem solid #fff; box-shadow: 0 12px 44px rgba(0,0,0,0.5); background: #11212b; }
    .lb-cap { font-family: var(--hand); font-size: 1.6rem; color: #fff; text-align: center; margin: 0.7rem 0 0; }
    .lb-close {
