    .polaroid:nth-child(odd) { transform: rotate(-2deg); }
    .polaroid:nth-child(even) { transform: rotate(1.6deg); }
    .polaroid:nth-child(3n) { transform: rotate(2.4deg); }
    .polaroid:hover { transform: rotate(0) scale(1.02); box-shadow: 3px 7px 0 rgba(24,18,12,0.22); }
    .polaroid:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
    .hint { font-size: 0.8rem; color: var(--muted); text-align: center; margin: 0.4rem 0 0; }
